# API/Worker Service Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# Temporal Configuration
TEMPORAL_HOST=temporal:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=prompt-tuning-queue

# Database Configuration
MONGODB_URI=mongodb://mongodb:27017
MONGODB_DATABASE=prompt_tuning

# Ollama Configuration (Host Machine)
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=gemma2

# LLM Configuration
GENERATOR_MODEL=gemma2
JUDGE_MODEL=gemma2
TEMPERATURE=0.7
MAX_TOKENS=2000

# Optimization Configuration
BATCH_SIZE=10
SCORE_THRESHOLD=7.0
EVALUATION_FREQUENCY_SECONDS=300
