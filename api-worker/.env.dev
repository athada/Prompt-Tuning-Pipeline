# Development mode environment variables
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# Temporal Configuration (local Docker instance)
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=prompt-tuning-queue

# Database Configuration (local Docker instance)
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=prompt_tuning

# Ollama Configuration (running on host)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma2

# LLM Configuration
GENERATOR_MODEL=gemma2
JUDGE_MODEL=gemma2
TEMPERATURE=0.7
MAX_TOKENS=2000

# Optimization Configuration
BATCH_SIZE=10
SCORE_THRESHOLD=7.0
EVALUATION_FREQUENCY_SECONDS=300
